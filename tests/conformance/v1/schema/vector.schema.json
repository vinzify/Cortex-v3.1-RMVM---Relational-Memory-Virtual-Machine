{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cortex.local/conformance/v1/vector.schema.json",
  "title": "Cortex RMVM Conformance Vector",
  "type": "object",
  "required": [
    "vector_id",
    "spec_version",
    "proto_version",
    "description",
    "manifest",
    "plan",
    "expect",
    "determinism"
  ],
  "properties": {
    "vector_id": {
      "type": "string",
      "pattern": "^C31-[A-Z]+-[0-9]{3}-[a-z0-9-]+$"
    },
    "spec_version": {
      "type": "string",
      "const": "conformance/v1.0.0"
    },
    "proto_version": {
      "type": "string",
      "const": "cortex_rmvm_v3_1"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "manifest": {
      "type": "object"
    },
    "plan": {
      "type": "object"
    },
    "execute_options": {
      "type": "object"
    },
    "expect": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "semantic_root": {
          "type": [
            "string",
            "null"
          ]
        },
        "verified_blocks": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "determinism": {
      "type": "object",
      "properties": {
        "assert_response_cpe_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "assert_semantic_root": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
